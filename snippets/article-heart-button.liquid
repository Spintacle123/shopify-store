{%- doc -%}
  Renders a client-side "heart/like" button for an article.

  This is stored in the visitor's browser (localStorage) and is not shared across devices/users.

  @param {object} article - Shopify article object
  @param {boolean} [show_text] - Show "Like/Liked" text
{%- enddoc -%}

{%- liquid
  assign target_article = article | default: closest.article
  assign show_text = show_text | default: false
-%}

{%- if target_article != blank -%}
  <button
    type="button"
    class="article-heart-button"
    data-article-heart="{{ target_article.id }}"
    aria-pressed="false"
  >
    <span class="article-heart-button__icon" aria-hidden="true">
      <svg
        viewBox="0 0 20 20"
        width="20"
        height="20"
        role="presentation"
        focusable="false"
      >
        {% render 'icon', icon: 'heart' %}
      </svg>
    </span>
    {%- if show_text -%}
      <span class="article-heart-button__text" data-article-heart-text>Like</span>
    {%- endif -%}
  </button>
{%- endif -%}

