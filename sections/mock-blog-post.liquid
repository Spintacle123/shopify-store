          "default": "3"
        },
        {
          "type": "textarea",
          "id": "caption",
          "label": "Caption",
          "default": "Savors every last bite. Our latest drop is here — crafted for those who appreciate quality."
        },
        {
          "type": "header",
          "content": "Comment 1"
        },
        {
          "type": "text",
          "id": "comment_1_author",
          "label": "Author",
          "default": "jamie"
        },
        {
          "type": "text",
          "id": "comment_1_text",
          "label": "Comment",
          "default": "Looks amazing. Can't wait to try this!"
