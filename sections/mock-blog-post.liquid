        {
          "type": "header",
          "content": "Comment 2"
        },
        {
          "type": "text",
          "id": "comment_2_author",
          "label": "Author",
          "default": "alex"
        },
        {
          "type": "text",
          "id": "comment_2_text",
          "label": "Comment",
          "default": "Where can I find the full catalog?"
        },
        {
          "type": "header",
          "content": "Comment 3"
        },
        {
          "type": "text",
          "id": "comment_3_author",
          "label": "Author",
          "default": ""
        },
        {
          "type": "text",
          "id": "comment_3_text",
          "label": "Comment",
          "default": ""
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Mock blog post",
      "blocks": [
        { "type": "post" },
        { "type": "post" },
        { "type": "post" }
      ]
    }
  ]
}
{% endschema %}
