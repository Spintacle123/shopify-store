<script
  src="{{ 'article-hearts.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

{%- comment -%} ── Modal overlay ── {%- endcomment -%}
<div class="ig-modal" id="igModal-{{ section.id }}" role="dialog" aria-modal="true" aria-label="Blog post" hidden>
  <div class="ig-modal__backdrop" data-ig-close></div>
  <div class="ig-modal__box">
    <button class="ig-modal__close" data-ig-close aria-label="Close">
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>

    {%- comment -%} Left: image {%- endcomment -%}
    <div class="ig-modal__image-side">
      <div class="ig-modal__image-wrap">
        <img class="ig-modal__image" src="" alt="" />
        <div class="ig-modal__image-placeholder" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="48" height="48" fill="none" stroke="currentColor" stroke-width="1.2">
            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
            <circle cx="8.5" cy="8.5" r="1.5"/>
            <polyline points="21 15 16 10 5 21"/>
          </svg>
        </div>
      </div>
    </div>

    {%- comment -%} Right: details + comments {%- endcomment -%}
    <div class="ig-modal__detail">

      <div class="ig-modal__header">
        <div class="ig-modal__avatar" aria-hidden="true">
          <span class="ig-modal__avatar-letter"></span>
        </div>
        <div class="ig-modal__header-text">
          <span class="ig-modal__username"></span>
          <span class="ig-modal__date"></span>
        </div>
      </div>

      <div class="ig-modal__body">
        <h2 class="ig-modal__title"></h2>
        <p class="ig-modal__caption"></p>
        <div class="ig-modal__likes">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor" aria-hidden="true">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
          </svg>
          <span class="ig-modal__likes-text"></span>
        </div>
      </div>

      <ul class="ig-modal__comments" role="list"></ul>

      <div class="ig-modal__add-comment">
        <input type="text" class="ig-modal__comment-input" placeholder="Add a comment…" aria-label="Add a comment" />
        <button type="button" class="ig-modal__post-btn">Post</button>
      </div>

    </div>
  </div>
</div>

{%- comment -%} ── Post data (hidden, read by JS) ── {%- endcomment -%}
<script type="application/json" id="igPosts-{{ section.id }}">
  [
    {% for block in section.blocks %}
      {% if block.type == 'post' %}
        {
          "title": {{ block.settings.title | default: '' | json }},
          "username": {{ block.settings.username | default: 'aerionix' | json }},
          "date": {{ block.settings.date | default: '' | json }},
          "likes": {{ block.settings.likes | default: '0' | json }},
          "caption": {{ block.settings.caption | default: '' | json }},
          "image": {% if block.settings.image != blank %}"{{ block.settings.image | image_url: width: 1200 }}"{% else %}""{% endif %},
          "comments": [
            {% if block.settings.comment_1_author != blank %}
              { "author": {{ block.settings.comment_1_author | json }}, "text": {{ block.settings.comment_1_text | default: '' | json }} }{% if block.settings.comment_2_author != blank or block.settings.comment_3_author != blank %},{% endif %}
            {% endif %}
            {% if block.settings.comment_2_author != blank %}
              { "author": {{ block.settings.comment_2_author | json }}, "text": {{ block.settings.comment_2_text | default: '' | json }} }{% if block.settings.comment_3_author != blank %},{% endif %}
            {% endif %}
            {% if block.settings.comment_3_author != blank %}
              { "author": {{ block.settings.comment_3_author | json }}, "text": {{ block.settings.comment_3_text | default: '' | json }} }
            {% endif %}
          ]
        }{% unless forloop.last %},{% endunless %}
      {% endif %}
    {% endfor %}
    {% if section.blocks.size == 0 %}
      { "title": "Sample Post Title", "username": "aerionix", "date": "Mar 31, 2026", "likes": "124", "caption": "Sample caption for this post.", "image": "", "comments": [{"author":"jamie","text":"Looks amazing!"},{"author":"alex","text":"Where can I get this?"}] },
      { "title": "Sample Post Title", "username": "aerionix", "date": "Mar 31, 2026", "likes": "124", "caption": "Sample caption for this post.", "image": "", "comments": [{"author":"jamie","text":"Looks amazing!"},{"author":"alex","text":"Where can I get this?"}] },
      { "title": "Sample Post Title", "username": "aerionix", "date": "Mar 31, 2026", "likes": "124", "caption": "Sample caption for this post.", "image": "", "comments": [{"author":"jamie","text":"Looks amazing!"},{"author":"alex","text":"Where can I get this?"}] }
    {% endif %}
  ]
</script>

{%- comment -%} ── Grid ── {%- endcomment -%}
<div class="ig-feed color-{{ section.settings.color_scheme }}">
  <div class="section-background color-{{ section.settings.color_scheme }}"></div>
  <div class="ig-feed__inner section spacing-style" style="{% render 'spacing-style', settings: section.settings %}">

    {% if section.settings.heading != blank %}
      <div class="ig-feed__header">
        <h2 class="ig-feed__title">{{ section.settings.heading }}</h2>
        {% if section.settings.subheading != blank %}
          <p class="ig-feed__subtitle">{{ section.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="ig-grid">

      {% for block in section.blocks %}
        {% if block.type == 'post' %}
          <article
            class="ig-card"
            {{ block.shopify_attributes }}
            data-ig-post="{{ forloop.index0 }}"
            data-section="{{ section.id }}"
            role="button"
            tabindex="0"
            aria-label="Open post: {{ block.settings.title | default: 'Blog post' }}"
          >
            <div class="ig-card__header">
              <div class="ig-card__avatar" aria-hidden="true">
                {%- if block.settings.avatar != blank -%}
                  {{
                    block.settings.avatar
                    | image_url: width: 80
                    | image_tag:
                      widths: '40, 80',
                      class: 'ig-card__avatar-img',
                      alt: block.settings.username,
                      loading: 'lazy'
                  }}
                {%- else -%}
                  <span class="ig-card__avatar-placeholder">{{ block.settings.username | slice: 0 | upcase }}</span>
                {%- endif -%}
              </div>
              <div class="ig-card__header-text">
                <span class="ig-card__username">{{ block.settings.username | default: 'aerionix' }}</span>
                <span class="ig-card__date">{{ block.settings.date }}</span>
              </div>
            </div>

            <div class="ig-card__image-wrap">
              {% if block.settings.image != blank %}
                {{
                  block.settings.image
                  | image_url: width: 800
                  | image_tag:
                    widths: '400, 600, 800',
                    class: 'ig-card__image',
                    sizes: '(min-width: 990px) 30vw, (min-width: 750px) 45vw, 90vw',
                    loading: 'lazy',
                    alt: block.settings.image.alt | default: block.settings.title
                }}
              {% else %}
                <div class="ig-card__image ig-card__image--placeholder">
                  <svg viewBox="0 0 24 24" width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.2" aria-hidden="true">
                    <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                    <circle cx="8.5" cy="8.5" r="1.5"/>
                    <polyline points="21 15 16 10 5 21"/>
                  </svg>
                </div>
              {% endif %}
              <div class="ig-card__overlay" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="28" height="28" fill="white" aria-hidden="true">
                  <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                </svg>
                <span>{{ block.settings.likes | default: '0' }}</span>
                <svg viewBox="0 0 24 24" width="28" height="28" fill="white" aria-hidden="true" style="margin-left:1rem">
                  <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                </svg>
                <span>{{ block.settings.comment_count | default: '0' }}</span>
              </div>
            </div>

            {% if block.settings.title != blank %}
              <h3 class="ig-card__title">{{ block.settings.title }}</h3>
            {% endif %}

            {% if block.settings.caption != blank %}
              <p class="ig-card__caption">
                <span class="ig-card__caption-username">{{ block.settings.username | default: 'aerionix' }}</span>
                {{ block.settings.caption }}
              </p>
            {% endif %}

          </article>
        {% endif %}
      {% endfor %}

      {% if section.blocks.size == 0 %}
        {% for i in (1..3) %}
          <article class="ig-card" data-ig-post="{{ forloop.index0 }}" data-section="{{ section.id }}" role="button" tabindex="0" aria-label="Open post">
            <div class="ig-card__header">
              <div class="ig-card__avatar"><span class="ig-card__avatar-placeholder">A</span></div>
              <div class="ig-card__header-text">
                <span class="ig-card__username">aerionix</span>
                <span class="ig-card__date">Mar 31, 2026</span>
              </div>
            </div>
            <div class="ig-card__image-wrap">
              <div class="ig-card__image ig-card__image--placeholder">
                <svg viewBox="0 0 24 24" width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.2" aria-hidden="true">
                  <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                  <circle cx="8.5" cy="8.5" r="1.5"/>
                  <polyline points="21 15 16 10 5 21"/>
                </svg>
              </div>
              <div class="ig-card__overlay" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="28" height="28" fill="white" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                <span>124</span>
                <svg viewBox="0 0 24 24" width="28" height="28" fill="white" aria-hidden="true" style="margin-left:1rem"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                <span>2</span>
              </div>
            </div>
            <h3 class="ig-card__title">Sample Post Title</h3>
            <p class="ig-card__caption"><span class="ig-card__caption-username">aerionix</span> Sample caption for this post.</p>
          </article>
        {% endfor %}
      {% endif %}

    </div>
  </div>
</div>

<script>
(function () {
  var sectionId = {{ section.id | json }};
  var modal     = document.getElementById('igModal-' + sectionId);
  var postsEl   = document.getElementById('igPosts-' + sectionId);
  if (!modal || !postsEl) return;

  var posts = JSON.parse(postsEl.textContent);

  function openPost(index) {
    var p = posts[index];
    if (!p) return;

    // image
    var imgEl   = modal.querySelector('.ig-modal__image');
    var phEl    = modal.querySelector('.ig-modal__image-placeholder');
    if (p.image) {
      imgEl.src = p.image;
      imgEl.alt = p.title || '';
      imgEl.hidden = false;
      phEl.hidden  = true;
    } else {
      imgEl.hidden = true;
      phEl.hidden  = false;
    }

    // header
    modal.querySelector('.ig-modal__avatar-letter').textContent = (p.username || 'A').charAt(0).toUpperCase();
    modal.querySelector('.ig-modal__username').textContent = p.username || '';
    modal.querySelector('.ig-modal__date').textContent     = p.date || '';

    // body
    modal.querySelector('.ig-modal__title').textContent       = p.title || '';
    modal.querySelector('.ig-modal__caption').textContent     = p.caption || '';
    modal.querySelector('.ig-modal__likes-text').textContent  = (p.likes || '0') + ' likes';

    // comments
    var ul = modal.querySelector('.ig-modal__comments');
    ul.innerHTML = '';
    (p.comments || []).forEach(function (c) {
      var li   = document.createElement('li');
      li.className = 'ig-modal__comment';
      var b    = document.createElement('span');
      b.className = 'ig-modal__comment-author';
      b.textContent = c.author;
      var t    = document.createElement('span');
      t.className = 'ig-modal__comment-text';
      t.textContent = ' ' + c.text;
      li.appendChild(b);
      li.appendChild(t);
      ul.appendChild(li);
    });

    modal.hidden = false;
    document.body.style.overflow = 'hidden';
    modal.querySelector('.ig-modal__close').focus();
  }

  function closeModal() {
    modal.hidden = true;
    document.body.style.overflow = '';
  }

  // Open on card click / enter
  document.querySelectorAll('[data-ig-post][data-section="' + sectionId + '"]').forEach(function (card) {
    card.addEventListener('click', function () { openPost(+card.dataset.igPost); });
    card.addEventListener('keydown', function (e) { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); openPost(+card.dataset.igPost); } });
  });

  // Close on backdrop / close button / Escape
  modal.querySelectorAll('[data-ig-close]').forEach(function (el) {
    el.addEventListener('click', closeModal);
  });
  document.addEventListener('keydown', function (e) { if (e.key === 'Escape' && !modal.hidden) closeModal(); });

  // Mock "Post" button
  modal.querySelector('.ig-modal__post-btn').addEventListener('click', function () {
    var input = modal.querySelector('.ig-modal__comment-input');
    var val   = input.value.trim();
    if (!val) return;
    var ul = modal.querySelector('.ig-modal__comments');
    var li = document.createElement('li');
    li.className = 'ig-modal__comment';
    li.innerHTML = '<span class="ig-modal__comment-author">you</span><span class="ig-modal__comment-text"> ' + val.replace(/</g,'&lt;') + '</span>';
    ul.appendChild(li);
    input.value = '';
    ul.scrollTop = ul.scrollHeight;
  });
})();
</script>

{% stylesheet %}
  /* ── Feed ───────────────────────────────────────── */
  .ig-feed__inner {
    max-width: 1080px;
    margin-inline: auto;
  }

  .ig-feed__header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .ig-feed__title {
    font-size: 1.5rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    margin: 0 0 0.4rem;
  }

  .ig-feed__subtitle {
    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text));
    font-size: var(--font-size--body-sm);
    margin: 0;
  }

  /* ── Grid ───────────────────────────────────────── */
  .ig-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  @media screen and (max-width: 749px) {
    .ig-grid { grid-template-columns: 1fr; gap: 2rem; }
  }

  @media screen and (min-width: 750px) and (max-width: 989px) {
    .ig-grid { grid-template-columns: repeat(2, 1fr); }
  }

  /* ── Card ───────────────────────────────────────── */
  .ig-card {
    display: flex;
    flex-direction: column;
    background: rgb(var(--color-background-rgb));
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.1);
    border-radius: 12px;
    overflow: hidden;
    font-size: 0.8125rem;
    line-height: 1.45;
    cursor: pointer;
    transition: box-shadow 0.2s, transform 0.2s;
  }

  .ig-card:hover {
    box-shadow: 0 8px 28px rgb(0 0 0 / 0.1);
    transform: translateY(-2px);
  }

  .ig-card:focus-visible {
    outline: 2px solid #3897f0;
    outline-offset: 2px;
  }

  /* ── Card header ────────────────────────────────── */
  .ig-card__header {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.7rem 0.8rem;
    border-bottom: 1px solid rgb(var(--color-foreground-rgb) / 0.06);
    pointer-events: none;
  }

  .ig-card__avatar {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    overflow: hidden;
    background: rgb(var(--color-foreground-rgb) / 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ig-card__avatar-img { width: 100%; height: 100%; object-fit: cover; display: block; }

  .ig-card__avatar-placeholder {
    font-size: 0.8rem;
    font-weight: 700;
    color: rgb(var(--color-foreground-rgb) / 0.5);
  }

  .ig-card__header-text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.05rem;
    min-width: 0;
  }

  .ig-card__username {
    font-weight: 600;
    font-size: 0.8125rem;
    color: rgb(var(--color-foreground-rgb));
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .ig-card__date {
    font-size: 0.7rem;
    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text));
  }

  /* ── Image ──────────────────────────────────────── */
  .ig-card__image-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: rgb(var(--color-foreground-rgb) / 0.05);
  }

  .ig-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.35s ease;
  }

  .ig-card:hover .ig-card__image:not(.ig-card__image--placeholder) {
    transform: scale(1.04);
  }

  .ig-card__image--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgb(var(--color-foreground-rgb) / 0.2);
    width: 100%;
    height: 100%;
  }

  /* Hover overlay (Instagram-style stats) */
  .ig-card__overlay {
    position: absolute;
    inset: 0;
    background: rgb(0 0 0 / 0.35);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    color: white;
    font-weight: 700;
    font-size: 1rem;
    opacity: 0;
    transition: opacity 0.2s;
    pointer-events: none;
  }

  .ig-card:hover .ig-card__overlay {
    opacity: 1;
  }

  /* ── Title ──────────────────────────────────────── */
  .ig-card__title {
    margin: 0;
    padding: 0.6rem 0.85rem 0.1rem;
    font-size: 0.875rem;
    font-weight: 700;
    line-height: 1.3;
    color: rgb(var(--color-foreground-rgb));
    letter-spacing: -0.01em;
    pointer-events: none;
  }

  /* ── Caption ─────────────────────────────────────── */
  .ig-card__caption {
    padding: 0.25rem 0.85rem 0.85rem;
    font-size: 0.8rem;
    color: rgb(var(--color-foreground-rgb) / 0.85);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    pointer-events: none;
  }

  .ig-card__caption-username {
    font-weight: 700;
    color: rgb(var(--color-foreground-rgb));
    margin-right: 0.35em;
  }

  /* ── Modal ───────────────────────────────────────── */
  .ig-modal {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }

  .ig-modal[hidden] { display: none; }

  .ig-modal__backdrop {
    position: absolute;
    inset: 0;
    background: rgb(0 0 0 / 0.65);
    cursor: pointer;
  }

  .ig-modal__box {
    position: relative;
    display: flex;
    width: 100%;
    max-width: 900px;
    max-height: 90vh;
    background: #fff;
    border-radius: 4px;
    overflow: hidden;
    box-shadow: 0 20px 60px rgb(0 0 0 / 0.3);
  }

  .ig-modal__close {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    z-index: 10;
    background: rgb(0 0 0 / 0.45);
    border: none;
    border-radius: 50%;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #fff;
    transition: background 0.15s;
  }

  .ig-modal__close:hover { background: rgb(0 0 0 / 0.65); }

  /* Left: image */
  .ig-modal__image-side {
    flex: 0 0 55%;
    background: #000;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ig-modal__image-wrap {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ig-modal__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ig-modal__image-placeholder {
    color: rgb(255 255 255 / 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
  }

  /* Right: detail */
  .ig-modal__detail {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-width: 0;
    max-height: 90vh;
    overflow: hidden;
  }

  .ig-modal__header {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.85rem 1rem;
    border-bottom: 1px solid #efefef;
    flex-shrink: 0;
  }

  .ig-modal__avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: #e9e9e9;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .ig-modal__avatar-letter {
    font-size: 0.85rem;
    font-weight: 700;
    color: #555;
  }

  .ig-modal__header-text {
    display: flex;
    flex-direction: column;
    gap: 0.05rem;
  }

  .ig-modal__username {
    font-weight: 700;
    font-size: 0.875rem;
    color: #262626;
  }

  .ig-modal__date {
    font-size: 0.72rem;
    color: #8e8e8e;
  }

  .ig-modal__body {
    padding: 0.85rem 1rem 0.5rem;
    border-bottom: 1px solid #efefef;
    flex-shrink: 0;
  }

  .ig-modal__title {
    font-size: 1rem;
    font-weight: 700;
    margin: 0 0 0.35rem;
    color: #262626;
    line-height: 1.3;
  }

  .ig-modal__caption {
    font-size: 0.85rem;
    color: #262626;
    margin: 0 0 0.6rem;
    line-height: 1.5;
  }

  .ig-modal__likes {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: #262626;
  }

  .ig-modal__likes svg { color: #e0245e; }

  .ig-modal__comments {
    flex: 1;
    overflow-y: auto;
    list-style: none;
    margin: 0;
    padding: 0.65rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .ig-modal__comment {
    font-size: 0.83rem;
    color: #262626;
    line-height: 1.45;
  }

  .ig-modal__comment-author {
    font-weight: 700;
    margin-right: 0.35em;
  }

  .ig-modal__comment-text { color: #262626; }

  .ig-modal__add-comment {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1rem;
    border-top: 1px solid #efefef;
    flex-shrink: 0;
  }

  .ig-modal__comment-input {
    flex: 1;
    border: none;
    outline: none;
    font-size: 0.83rem;
    color: #262626;
    background: transparent;
  }

  .ig-modal__comment-input::placeholder { color: #aaa; }

  .ig-modal__post-btn {
    background: none;
    border: none;
    font-size: 0.83rem;
    font-weight: 700;
    color: #3897f0;
    cursor: pointer;
    padding: 0;
    flex-shrink: 0;
    transition: opacity 0.15s;
  }

  .ig-modal__post-btn:hover { opacity: 0.65; }

  @media screen and (max-width: 749px) {
    .ig-modal__box { flex-direction: column; max-height: 95vh; }
    .ig-modal__image-side { flex: 0 0 45vw; min-height: 240px; }
  }
{% endstylesheet %}

