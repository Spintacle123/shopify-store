    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "post",
      "name": "Post",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Savors every last bite"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "image_picker",
          "id": "avatar",
          "label": "Avatar"
        },
        {
          "type": "text",
          "id": "username",
          "label": "Username",
          "default": "aerionix"
        },
        {
          "type": "text",
          "id": "date",
          "label": "Date",
          "default": "Mar 31, 2026"
        },
        {
          "type": "text",
          "id": "likes",
