<script
  src="{{ 'article-hearts.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

<div class="ig-feed color-{{ section.settings.color_scheme }}">
  <div class="section-background color-{{ section.settings.color_scheme }}"></div>
  <div class="ig-feed__inner section spacing-style" style="{% render 'spacing-style', settings: section.settings %}">

    {% if section.settings.heading != blank %}
      <div class="ig-feed__header">
        <h2 class="ig-feed__title">{{ section.settings.heading }}</h2>
        {% if section.settings.subheading != blank %}
          <p class="ig-feed__subtitle">{{ section.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="ig-grid">
      {% for block in section.blocks %}
        {% if block.type == 'post' %}
          <article class="ig-card" {{ block.shopify_attributes }}>

            {%- comment -%} ── Card header: avatar + username + date ── {%- endcomment -%}
            <div class="ig-card__header">
              <div class="ig-card__avatar" aria-hidden="true">
                {%- if block.settings.avatar != blank -%}
                  {{
                    block.settings.avatar
                    | image_url: width: 80
                    | image_tag:
                      widths: '40, 80',
                      class: 'ig-card__avatar-img',
                      alt: block.settings.username,
                      loading: 'lazy'
                  }}
                {%- else -%}
                  <span class="ig-card__avatar-placeholder">{{ block.settings.username | slice: 0 | upcase }}</span>
                {%- endif -%}
              </div>
              <div class="ig-card__header-text">
                <span class="ig-card__username">{{ block.settings.username | default: 'aerionix' }}</span>
                <span class="ig-card__date">{{ block.settings.date }}</span>
              </div>
              <button
                type="button"
                class="ig-card__heart article-heart-button"
                data-article-heart="{{ section.id }}-{{ forloop.index }}"
                aria-pressed="false"
                aria-label="Like post"
              >
                <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
                  <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                </svg>
              </button>
            </div>

            {%- comment -%} ── Square image ── {%- endcomment -%}
            <div class="ig-card__image-wrap">
              {% if block.settings.image != blank %}
                {{
                  block.settings.image
                  | image_url: width: 800
                  | image_tag:
                    widths: '400, 600, 800',
                    class: 'ig-card__image',
                    sizes: '(min-width: 990px) 30vw, (min-width: 750px) 45vw, 90vw',
                    loading: 'lazy',
                    alt: block.settings.image.alt | default: block.settings.caption
                }}
              {% else %}
                <div class="ig-card__image ig-card__image--placeholder">
                  <svg viewBox="0 0 24 24" width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.2" aria-hidden="true" focusable="false">
                    <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                    <circle cx="8.5" cy="8.5" r="1.5"/>
                    <polyline points="21 15 16 10 5 21"/>
                  </svg>
                </div>
              {% endif %}
            </div>

            {%- comment -%} ── Actions bar ── {%- endcomment -%}
            <div class="ig-card__actions">
              <div class="ig-card__actions-left">
                <span class="ig-card__like-count">
                  <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true" focusable="false">
                    <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                  </svg>
                  {{ block.settings.likes | default: '0' }} likes
                </span>
              </div>
              <span class="ig-card__comment-count">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
                  <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                </svg>
                {{ block.settings.comment_count | default: '0' }}
              </span>
            </div>

            {%- comment -%} ── Title ── {%- endcomment -%}
            {% if block.settings.title != blank %}
              <h3 class="ig-card__title">{{ block.settings.title }}</h3>
            {% endif %}

            {%- comment -%} ── Caption ── {%- endcomment -%}
            {% if block.settings.caption != blank %}
              <div class="ig-card__caption">
                <span class="ig-card__caption-username">{{ block.settings.username | default: 'aerionix' }}</span>
                {{ block.settings.caption }}
              </div>
            {% endif %}

            {%- comment -%} ── Comments ── {%- endcomment -%}
            {% assign has_comments = false %}
            {% if block.settings.comment_1_author != blank %}{% assign has_comments = true %}{% endif %}
            {% if block.settings.comment_2_author != blank %}{% assign has_comments = true %}{% endif %}
            {% if block.settings.comment_3_author != blank %}{% assign has_comments = true %}{% endif %}

            {% if has_comments %}
              <ul class="ig-card__comments" role="list">
                {% if block.settings.comment_1_author != blank %}
                  <li class="ig-card__comment">
                    <span class="ig-card__comment-author">{{ block.settings.comment_1_author }}</span>
                    <span class="ig-card__comment-text">{{ block.settings.comment_1_text }}</span>
                  </li>
                {% endif %}
                {% if block.settings.comment_2_author != blank %}
                  <li class="ig-card__comment">
                    <span class="ig-card__comment-author">{{ block.settings.comment_2_author }}</span>
                    <span class="ig-card__comment-text">{{ block.settings.comment_2_text }}</span>
                  </li>
                {% endif %}
                {% if block.settings.comment_3_author != blank %}
                  <li class="ig-card__comment">
                    <span class="ig-card__comment-author">{{ block.settings.comment_3_author }}</span>
                    <span class="ig-card__comment-text">{{ block.settings.comment_3_text }}</span>
                  </li>
                {% endif %}
              </ul>
            {% endif %}

            {%- comment -%} ── Add comment input ── {%- endcomment -%}
            <div class="ig-card__add-comment">
              <input
                type="text"
                class="ig-card__comment-input"
                placeholder="Add a comment…"
                aria-label="Add a comment"
              />
              <button type="button" class="ig-card__post-btn">Post</button>
            </div>

          </article>
        {% endif %}
      {% endfor %}

      {% if section.blocks.size == 0 %}
        {%- comment -%} Placeholder cards when no blocks are added ── {%- endcomment -%}
        {% for i in (1..3) %}
          <article class="ig-card ig-card--placeholder">
            <div class="ig-card__header">
              <div class="ig-card__avatar"><span class="ig-card__avatar-placeholder">A</span></div>
              <div class="ig-card__header-text">
                <span class="ig-card__username">aerionix</span>
                <span class="ig-card__date">Mar 31, 2026</span>
              </div>
            </div>
            <div class="ig-card__image-wrap">
              <div class="ig-card__image ig-card__image--placeholder">
                <svg viewBox="0 0 24 24" width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.2" aria-hidden="true" focusable="false">
                  <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                  <circle cx="8.5" cy="8.5" r="1.5"/>
                  <polyline points="21 15 16 10 5 21"/>
                </svg>
              </div>
            </div>
            <div class="ig-card__actions">
              <span class="ig-card__like-count">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true" focusable="false">
                  <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                </svg>
                124 likes
              </span>
            </div>
            <h3 class="ig-card__title">Sample Post Title</h3>
            <div class="ig-card__caption">
              <span class="ig-card__caption-username">aerionix</span>
              Sample caption for this post. Add your own content here.
            </div>
            <ul class="ig-card__comments" role="list">
              <li class="ig-card__comment"><span class="ig-card__comment-author">jamie</span><span class="ig-card__comment-text">Looks amazing!</span></li>
              <li class="ig-card__comment"><span class="ig-card__comment-author">alex</span><span class="ig-card__comment-text">Where can I get this?</span></li>
            </ul>
            <div class="ig-card__add-comment">
              <input type="text" class="ig-card__comment-input" placeholder="Add a comment…" aria-label="Add a comment" />
              <button type="button" class="ig-card__post-btn">Post</button>
            </div>
          </article>
        {% endfor %}
      {% endif %}
    </div>

  </div>
</div>

{% stylesheet %}
  /* ── Feed wrapper ───────────────────────────────── */
  .ig-feed__inner {
    max-width: 1080px;
    margin-inline: auto;
  }

  .ig-feed__header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .ig-feed__title {
    font-size: 1.5rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    margin: 0 0 0.4rem;
  }

  .ig-feed__subtitle {
    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text));
    font-size: var(--font-size--body-sm);
    margin: 0;
  }

  /* ── 3-column grid ──────────────────────────────── */
  .ig-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  @media screen and (max-width: 749px) {
    .ig-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }

  @media screen and (min-width: 750px) and (max-width: 989px) {
    .ig-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* ── Card ───────────────────────────────────────── */
  .ig-card {
    display: flex;
    flex-direction: column;
    background: rgb(var(--color-background-rgb));
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.1);
    border-radius: 12px;
    overflow: hidden;
    font-size: 0.8125rem;
    line-height: 1.45;
  }

  /* ── Card header ────────────────────────────────── */
  .ig-card__header {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.7rem 0.8rem 0.7rem 0.75rem;
    border-bottom: 1px solid rgb(var(--color-foreground-rgb) / 0.06);
  }

  .ig-card__avatar {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    overflow: hidden;
    background: rgb(var(--color-foreground-rgb) / 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ig-card__avatar-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ig-card__avatar-placeholder {
    font-size: 0.8rem;
    font-weight: 700;
    color: rgb(var(--color-foreground-rgb) / 0.5);
  }

  .ig-card__header-text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.05rem;
    min-width: 0;
  }

  .ig-card__username {
    font-weight: 600;
    font-size: 0.8125rem;
    color: rgb(var(--color-foreground-rgb));
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .ig-card__date {
    font-size: 0.7rem;
    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text));
  }

  /* Heart button in header */
  .ig-card__heart {
    flex-shrink: 0;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    color: rgb(var(--color-foreground-rgb) / 0.4);
    display: flex;
    align-items: center;
    border-radius: 50%;
    transition: color 0.2s, transform 0.15s;
  }

  .ig-card__heart:hover,
  .ig-card__heart[aria-pressed="true"] {
    color: #e0245e;
    transform: scale(1.15);
  }

  /* ── Image ──────────────────────────────────────── */
  .ig-card__image-wrap {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: rgb(var(--color-foreground-rgb) / 0.05);
  }

  .ig-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.35s ease;
  }

  .ig-card:hover .ig-card__image:not(.ig-card__image--placeholder) {
    transform: scale(1.03);
  }

  .ig-card__image--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgb(var(--color-foreground-rgb) / 0.2);
    width: 100%;
    height: 100%;
  }

  /* ── Actions bar ─────────────────────────────────── */
  .ig-card__actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.55rem 0.85rem 0.1rem;
    gap: 0.5rem;
  }

  .ig-card__actions-left {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .ig-card__like-count,
  .ig-card__comment-count {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.75rem;
    font-weight: 500;
    color: rgb(var(--color-foreground-rgb) / 0.7);
  }

  .ig-card__like-count svg {
    color: #e0245e;
  }

  /* ── Title ──────────────────────────────────────── */
  .ig-card__title {
    margin: 0;
    padding: 0.55rem 0.85rem 0.1rem;
    font-size: 0.875rem;
    font-weight: 700;
    line-height: 1.3;
    color: rgb(var(--color-foreground-rgb));
    letter-spacing: -0.01em;
  }

  /* ── Caption ─────────────────────────────────────── */
  .ig-card__caption {
    padding: 0.35rem 0.85rem 0.1rem;
    font-size: 0.8rem;
    color: rgb(var(--color-foreground-rgb) / 0.85);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .ig-card__caption-username {
    font-weight: 700;
    color: rgb(var(--color-foreground-rgb));
    margin-right: 0.35em;
  }

  /* ── Comments ────────────────────────────────────── */
  .ig-card__comments {
    list-style: none;
    margin: 0;
    padding: 0.3rem 0.85rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .ig-card__comment {
    font-size: 0.78rem;
    color: rgb(var(--color-foreground-rgb) / 0.8);
    line-height: 1.4;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .ig-card__comment-author {
    font-weight: 700;
    color: rgb(var(--color-foreground-rgb));
    margin-right: 0.35em;
  }

  /* ── Add comment ─────────────────────────────────── */
  .ig-card__add-comment {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.55rem 0.85rem 0.75rem;
    margin-top: auto;
    border-top: 1px solid rgb(var(--color-foreground-rgb) / 0.07);
    margin-top: 0.5rem;
  }

  .ig-card__comment-input {
    flex: 1;
    border: none;
    outline: none;
    background: transparent;
    font-size: 0.78rem;
    color: rgb(var(--color-foreground-rgb));
    placeholder-color: rgb(var(--color-foreground-rgb) / 0.4);
  }

  .ig-card__comment-input::placeholder {
    color: rgb(var(--color-foreground-rgb) / 0.38);
  }

  .ig-card__post-btn {
    background: none;
    border: none;
    font-size: 0.78rem;
    font-weight: 600;
    color: #3897f0;
    cursor: pointer;
    padding: 0;
    flex-shrink: 0;
    transition: opacity 0.15s;
  }

  .ig-card__post-btn:hover {
    opacity: 0.7;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Mock blog post",
  "tag": "section",
  "class": "mock-blog-post",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Latest Posts"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "What's happening at Aerionix"
    },
    {
      "type": "color_scheme",
