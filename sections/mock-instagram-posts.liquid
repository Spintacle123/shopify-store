<script
  src="{{ 'article-hearts.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

{% liquid
  assign color_scheme = section.settings.color_scheme
%}

<section class="mock-posts color-{{ color_scheme }}">
  <div class="section-background color-{{ color_scheme }}"></div>
  <div class="section spacing-style" style="{% render 'spacing-style', settings: section.settings %}">
    {% if section.settings.heading != blank %}
      <header class="mock-posts__header">
        <h1 class="h2">{{ section.settings.heading }}</h1>
        {% if section.settings.subheading != blank %}
          <div class="rte">{{ section.settings.subheading }}</div>
        {% endif %}
      </header>
    {% endif %}

    <div class="mock-posts__grid" role="list">
      {% for block in section.blocks %}
        {% liquid
          assign image = block.settings.image
          assign url = block.settings.url
        %}
        <article class="mock-posts__card" role="listitem" {{ block.shopify_attributes }}>
          <div class="mock-posts__heart">
            <button
              type="button"
              class="article-heart-button"
              data-article-heart="{{ block.id }}"
              aria-pressed="false"
              aria-label="Like"
            >
              <span class="article-heart-button__icon" aria-hidden="true">
                <svg viewBox="0 0 20 20" width="20" height="20" role="presentation" focusable="false">
                  {% render 'icon', icon: 'heart' %}
                </svg>
              </span>
            </button>
          </div>

          <a class="mock-posts__link" href="{{ url | default: '#' }}">
            {% if image != blank %}
              {{
                image
                | image_url: width: 1600
                | image_tag:
                  widths: '240, 352, 832, 1200, 1600',
                  class: 'mock-posts__image',
                  sizes: '(min-width: 990px) 30vw, 100vw',
                  loading: 'lazy',
                  alt: image.alt
              }}
            {% else %}
              <div class="mock-posts__image mock-posts__image--placeholder"></div>
            {% endif %}

            <div class="mock-posts__meta">
              <h2 class="h4 mock-posts__title">{{ block.settings.title | default: 'Instagram Post' }}</h2>
              {% if block.settings.description != blank %}
                <div class="mock-posts__desc">
                  {{ block.settings.description | strip_html | truncate: 140 }}
                </div>
              {% endif %}

              <div class="mock-posts__stats">
                <span class="mock-posts__stat">
                  <svg viewBox="0 0 20 20" width="18" height="18" role="presentation" focusable="false">
                    {% render 'icon', icon: 'chat_bubble' %}
                  </svg>
                  <span>{{ block.settings.comments_count | default: 0 }}</span>
                </span>
                <span class="mock-posts__stat">
                  <svg viewBox="0 0 20 20" width="18" height="18" role="presentation" focusable="false">
                    {% render 'icon', icon: 'eye' %}
                  </svg>
                  <span>{{ block.settings.views_count | default: 0 }}</span>
                </span>
              </div>
            </div>
          </a>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
  .mock-posts__header {
    max-width: var(--normal-content-width);
    margin: 0 auto var(--margin-xl);
    display: grid;
    gap: var(--gap-sm);
  }

  .mock-posts__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--gap-lg);
    max-width: var(--page-width);
    margin: 0 auto;
  }

  @media screen and (min-width: 750px) {
    .mock-posts__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (min-width: 990px) {
    .mock-posts__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .mock-posts__card {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid rgb(var(--color-foreground-rgb) / var(--opacity-20));
    background: rgb(var(--color-background-rgb) / 0.6);
  }

  .mock-posts__link {
    display: grid;
    grid-template-rows: auto 1fr;
    text-decoration: none;
    color: inherit;
  }

  .mock-posts__image {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    display: block;
    background: rgb(var(--color-foreground-rgb) / var(--opacity-5));
  }

  .mock-posts__image--placeholder {
    background: linear-gradient(
      135deg,
      rgb(var(--color-foreground-rgb) / var(--opacity-10)),
      rgb(var(--color-foreground-rgb) / var(--opacity-5))
    );
  }

  .mock-posts__meta {
    padding: var(--padding-lg);
    display: grid;
    gap: var(--gap-xs);
  }

  .mock-posts__desc {
    font-size: var(--font-size--body-sm);
    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text));
  }

  .mock-posts__stats {
    margin-top: var(--margin-xs);
    display: flex;
    gap: var(--gap-md);
    align-items: center;
    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text));
    font-size: var(--font-size--body-sm);
  }

  .mock-posts__stat {
    display: inline-flex;
    gap: 0.35rem;
    align-items: center;
  }

  .mock-posts__heart {
    position: absolute;
    top: 12px;
    right: 12px;
    z-index: 2;
  }

  .mock-posts__heart .article-heart-button {
    background: rgb(var(--color-background-rgb) / 0.88);
    backdrop-filter: blur(6px);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Mock Instagram posts",
  "tag": "section",
  "class": "mock-instagram-posts",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Instagram Posts"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "<p>A mock feed to preview the design.</p>"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "post",
      "name": "Post",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "New drop — behind the scenes"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description",
          "default": "<p>Write a short description to preview the card layout.</p>"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link",
          "info": "Optional. Link to a page (e.g. your mock blog post page)."
        },
        {
          "type": "number",
          "id": "comments_count",
          "label": "Comments",
          "default": 12
        },
        {
          "type": "number",
          "id": "views_count",
          "label": "Views",
          "default": 318
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Mock Instagram posts",
      "blocks": [
        { "type": "post" },
        { "type": "post" },
        { "type": "post" }
      ]
    }
  ]
}
{% endschema %}

